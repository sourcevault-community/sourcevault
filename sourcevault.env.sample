# SourceVault Environment Configuration Sample
# Copy this file to 'sourcevault.env' and modify as needed.

# The root directory for all SourceVault data.
# Default: /home/sourcevault
# SOURCEVAULT_ROOT_DIR=/home/sourcevault

# Path where logs will be written. 
# Relative paths are resolved against ROOT_DIR.
# If empty, logs go to stdout/stderr.
# SOURCEVAULT_LOG_FILE=logs/sourcevault.log

# The log verbosity level: ERROR, WARN, INFO, DEBUG.
# If unset, DEBUG mode will automatically select DEBUG.
# SOURCEVAULT_LOG_LEVEL=INFO

# Database Configuration
# Driver can be 'sqlite3'. In the future 'postgres' may be supported.
# SOURCEVAULT_DB_DRIVER=sqlite3
# For sqlite3, DSN is the file path. For postgres, it would be a connection URI.
# SOURCEVAULT_DB_DSN=sourcevault.db

# Enable verbose logging and diagnostic features.
# SOURCEVAULT_DEBUG=true

# Enable the internal administrative web interface.
# SOURCEVAULT_WEB_ENABLED=false

# IP address or hostname the web server will bind to.
# SOURCEVAULT_WEB_HOST=127.0.0.1

# TCP port the web server will listen on.
# SOURCEVAULT_WEB_PORT=8080

# Enable the dedicated network-isolated metrics server.
# SOURCEVAULT_METRICS_ENABLED=true

# IP address or hostname the metrics server will bind to (default 127.0.0.1 for security).
# SOURCEVAULT_METRICS_HOST=127.0.0.1

# TCP port the metrics server will listen on.
# SOURCEVAULT_METRICS_PORT=9090

# Enable the built-in SSH server for Git operations.
# SOURCEVAULT_SSH_ENABLED=true

# IP address or hostname the SSH server will bind to.
# SOURCEVAULT_SSH_HOST=0.0.0.0

# TCP port the SSH server will listen on.
# SOURCEVAULT_SSH_PORT=2222
